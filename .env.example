SOURCE_BASE_URL=https://source-store.example.com
SOURCE_SITEMAP_INDEX_URL=https://source-store.example.com/sitemap_index.xml

WC_BASE_URL=https://your-store.example.com
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional runtime flags (loaded from .env via dotenv on startup)
FULL_SYNC=false
FULL_SCRAPE=false
MAX_PRODUCTS=
MAX_CATEGORIES=
MAX_PER_RUN=

# node src/run-batch.js: first UTC day run = full sitemap + category + brand sync; later runs use
# product-sitemap-cache.json + skip category/brand (see src/batch-schedule.js).
# DAILY_FULL_SYNC=true
# FORCE_INCREMENTAL_SYNC=true

# Product sync: backfill Woo from products.json (default true via run-batch) — up to MAX_PER_RUN
# products not already in Woo per run. Set false to use sitemap queue only (legacy).
# PRODUCT_SYNC_BACKFILL=true
